<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Software Inventory</title>
<style>
  :root {
    --bg: #f4f6f9; --card: #ffffff; --border: #dee2e6;
    --primary: #2563eb; --primary-hover: #1d4ed8;
    --text: #1e293b; --text-muted: #64748b;
    --badge-blue: #e0e7ff; --badge-blue-text: #3730a3;
    --badge-red: #fee2e2; --badge-red-text: #991b1b;
    --badge-green: #dcfce7; --badge-green-text: #166534;
    --row-hover: #f1f5f9; --shadow: 0 1px 3px rgba(0,0,0,.1);
    --radius: 8px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: var(--bg); color: var(--text); font-size: 14px; padding: 16px; }
  .header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap; }
  .header h1 { font-size: 18px; font-weight: 700; flex: 1; }
  .stat-pill { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 4px 14px; font-size: 12px; color: var(--text-muted); font-weight: 500; white-space: nowrap; }
  .stat-pill strong { color: var(--primary); }
  .toolbar { display: flex; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; align-items: center; }
  .search-wrap { position: relative; flex: 1; min-width: 180px; }
  .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none; }
  .search-input { width: 100%; padding: 8px 12px 8px 32px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 14px; background: var(--card); outline: none; }
  .search-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,.15); }
  select.flt { padding: 7px 10px; border: 1px solid var(--border); border-radius: var(--radius); font-size: 13px; background: var(--card); cursor: pointer; outline: none; }
  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: var(--radius); font-size: 13px; font-weight: 600; cursor: pointer; border: none; transition: background .15s; white-space: nowrap; }
  .btn-primary { background: var(--primary); color: #fff; }
  .btn-primary:hover { background: var(--primary-hover); }
  .btn-outline { background: var(--card); color: var(--text); border: 1px solid var(--border); }
  .btn-outline:hover { background: var(--row-hover); }
  .btn:disabled { opacity: .5; cursor: not-allowed; }
  .table-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); overflow: auto; }
  table { width: 100%; border-collapse: collapse; }
  thead { position: sticky; top: 0; z-index: 2; }
  th { background: #f8fafc; border-bottom: 2px solid var(--border); padding: 9px 14px; text-align: left; font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .04em; cursor: pointer; user-select: none; white-space: nowrap; }
  th:hover { color: var(--primary); }
  th.sorted { color: var(--primary); }
  td { padding: 9px 14px; border-bottom: 1px solid var(--border); vertical-align: middle; max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--row-hover); }
  .icon-cell { display: flex; align-items: center; gap: 9px; max-width: 260px; }
  .app-icon { width: 26px; height: 26px; border-radius: 5px; object-fit: contain; flex-shrink: 0; background: #fff; border: 1px solid var(--border); padding: 2px; }
  .app-name { font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .app-ver { font-size: 11px; color: var(--text-muted); margin-top: 1px; }
  .badge { display: inline-block; padding: 2px 7px; border-radius: 10px; font-size: 11px; font-weight: 600; white-space: nowrap; }
  .b-arch { background: var(--badge-blue); color: var(--badge-blue-text); }
  .b-sys { background: var(--badge-red); color: var(--badge-red-text); }
  .b-usr { background: var(--badge-green); color: var(--badge-green-text); }
  .state-box { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 24px; gap: 12px; color: var(--text-muted); }
  .spinner { width: 34px; height: 34px; border: 3px solid var(--border); border-top-color: var(--primary); border-radius: 50%; animation: spin .7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .pager { display: flex; align-items: center; justify-content: space-between; padding: 10px 16px; border-top: 1px solid var(--border); font-size: 12px; color: var(--text-muted); flex-wrap: wrap; gap: 8px; }
  .pager-btns { display: flex; gap: 5px; }
  .pager-btn { padding: 3px 9px; border: 1px solid var(--border); border-radius: 5px; background: var(--card); cursor: pointer; font-size: 12px; color: var(--text); }
  .pager-btn:hover { background: var(--row-hover); }
  .pager-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }
  .pager-btn:disabled { opacity: .4; cursor: not-allowed; }
  .toast-wrap { position: fixed; bottom: 18px; right: 18px; z-index: 9999; display: flex; flex-direction: column; gap: 8px; }
  .toast { background: #1e293b; color: #fff; padding: 9px 16px; border-radius: var(--radius); font-size: 13px; box-shadow: 0 4px 12px rgba(0,0,0,.25); animation: fi .2s ease; }
  @keyframes fi { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; } }
</style>
</head>
<body>
<div id="app">
  <div class="header">
    <h1>&#128220; Software Instalado</h1>
    <div class="stat-pill">Total: <strong id="cntTotal"></strong></div>
    <div class="stat-pill" id="statShow" style="display:none">Filtrado: <strong id="cntShow"></strong></div>
    <div class="stat-pill" id="statTs" style="display:none">Atualizado: <strong id="tsVal"></strong></div>
  </div>

  <div class="toolbar">
    <div class="search-wrap">
      <span class="search-icon">&#128269;</span>
      <input id="searchInput" class="search-input" type="text" placeholder="Buscar por nome, publisher ou versão" oninput="applyFilters()">
    </div>
    <select id="fltArch" class="flt" onchange="applyFilters()">
      <option value="">Todas arquiteturas</option>
      <option value="x64">x64 (64-bit)</option>
      <option value="x86">x86 (32-bit)</option>
    </select>
    <select id="fltType" class="flt" onchange="applyFilters()">
      <option value="">Todos os tipos</option>
      <option value="user">Usuário</option>
      <option value="system">Sistema</option>
    </select>
    <button class="btn btn-outline" onclick="exportCSV()" id="btnExport" disabled>&#8659; CSV</button>
    <button class="btn btn-primary" onclick="loadData(true)" id="btnRefresh">&#8635; Atualizar</button>
  </div>

  <div class="table-wrap">
    <div id="stateLoading" class="state-box"><div class="spinner"></div><p>Consultando dispositivo</p></div>
    <div id="stateError" class="state-box" style="display:none"><p>&#9888;</p><p id="errMsg">Erro ao carregar dados</p><small>Verifique se o dispositivo está online.</small></div>
    <div id="stateEmpty" class="state-box" style="display:none"><p>&#128230;</p><p id="emptyMsg">Nenhum software encontrado.</p></div>
    <table id="mainTable" style="display:none">
      <thead><tr>
        <th onclick="sortBy('name')" id="th-name">Aplicativo <span id="arr-name"></span></th>
        <th onclick="sortBy('publisher')" id="th-publisher">Publisher <span id="arr-publisher"></span></th>
        <th onclick="sortBy('installDate')" id="th-installDate">Data Instalação <span id="arr-installDate"></span></th>
        <th onclick="sortBy('installSizeRaw')" id="th-installSizeRaw">Tamanho <span id="arr-installSizeRaw"></span></th>
        <th onclick="sortBy('architecture')" id="th-architecture">Arch <span id="arr-architecture"></span></th>
        <th>Tipo</th>
      </tr></thead>
      <tbody id="tableBody"></tbody>
    </table>
    <div class="pager" id="pager" style="display:none">
      <div id="pageInfo"></div>
      <div class="pager-btns">
        <button class="pager-btn" id="btnPrev" onclick="changePage(-1)">&#8592; Anterior</button>
        <button class="pager-btn" id="btnNext" onclick="changePage(1)">Próxima &#8594;</button>
      </div>
      <select class="flt" id="pageSz" onchange="changePageSize()" style="min-width:80px">
        <option value="25">25/pág</option>
        <option value="50" selected>50/pág</option>
        <option value="100">100/pág</option>
        <option value="250">250/pág</option>
      </select>
    </div>
  </div>
</div>
<div class="toast-wrap" id="toastWrap"></div>

<script>
// Node ID pode ser injetado pelo servidor via Handlebars ({{nodeid}}).
// Em alguns UIs/versões do MeshCentral a variável global do parent pode
// fornecer o node id; tente usar ambos (fallback para parent frames).
var DEVICE_ID = '{{nodeid}}';
var PLUGIN_PIN = '{{pluginPin}}';

// Fallback robusto: percorre a cadeia de frames pais e tenta várias propriedades
function findDeviceIdInFrames() {
  var w = window;
  try {
    while (w) {
      try {
        if (w.currentNodeId) return w.currentNodeId;
        if (w.nodeid) return w.nodeid;
        if (w.DEVICE_ID) return w.DEVICE_ID;
        if (w.Device && w.Device.node && w.Device.node._id) return w.Device.node._id;
        if (w.DeviceId) return w.DeviceId;
        if (w.location && typeof w.location.href === 'string') {
          var p = new URL(w.location.href);
          var q = p.searchParams.get('id') || p.searchParams.get('nodeid') || p.searchParams.get('device') || p.searchParams.get('deviceid');
          if (q) return q;
        }
      } catch (e) {
        // ignorar cross-origin ou propriedades inacessíveis e continuar subindo
      }
      if (!w.parent || w.parent === w) break;
      w = w.parent;
    }
  } catch (e) {}
  return '';
}

if (!DEVICE_ID || DEVICE_ID === '') {
  var found = findDeviceIdInFrames();
  if (found) DEVICE_ID = found;
}

var DATA_URL = '/pluginadmin.ashx?pin=' + PLUGIN_PIN + '&user=1&action=data' + (DEVICE_ID ? '&nodeid=' + encodeURIComponent(DEVICE_ID) : '');

var allApps = [], filteredApps = [];
var sortField = 'name', sortAsc = true;
var currentPage = 1, pageSize = 50;

window.addEventListener('DOMContentLoaded', function () {
  if (!DEVICE_ID) { showError('Nenhum ID de dispositivo fornecido.'); return; }
  loadData(false);
});

function loadData(force) {
  setState('loading');
  document.getElementById('btnRefresh').disabled = true;
  var url = DATA_URL + (force ? '&refresh=1' : '');
  fetch(url)
    .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(function (json) {
      if (!json.success) throw new Error(json.error || 'Resposta inválida');
      allApps = json.softwares || [];
      if (json.timestamp) {
        document.getElementById('tsVal').textContent = new Date(json.timestamp).toLocaleString('pt-BR');
        document.getElementById('statTs').style.display = '';
      }
      if (allApps.length === 0) { setState('empty'); updateStats(0, 0); }
      else { applyFilters(); document.getElementById('btnExport').disabled = false; }
      if (json.source === 'empty' || json.source === 'timeout') {
        toast(json.message || 'Agente não respondeu. Verifique se está online e tente novamente.');
      } else if (json.source === 'agent-live') {
        toast('✓ Dados coletados ao vivo do agente (' + (json.count||0) + ' apps).');
      }
    })
    .catch(function (err) { showError(err.message); })
    .finally(function () { document.getElementById('btnRefresh').disabled = false; });
}

function applyFilters() {
  var q = document.getElementById('searchInput').value.toLowerCase().trim();
  var arch = document.getElementById('fltArch').value;
  var type = document.getElementById('fltType').value;
  filteredApps = allApps.filter(function (a) {
    if (q && !(a.name + ' ' + a.publisher + ' ' + a.version).toLowerCase().includes(q)) return false;
    if (arch && a.architecture !== arch) return false;
    if (type === 'system' && !a.systemComponent) return false;
    if (type === 'user' && a.systemComponent) return false;
    return true;
  });
  sortApps(); currentPage = 1; renderTable();
  updateStats(allApps.length, filteredApps.length);
  if (filteredApps.length === 0 && allApps.length > 0) { setState('empty'); document.getElementById('emptyMsg').textContent = 'Nenhum resultado para os filtros aplicados.'; }
  else if (filteredApps.length > 0) setState('table');
}

function sortBy(field) {
  if (sortField === field) sortAsc = !sortAsc; else { sortField = field; sortAsc = true; }
  document.querySelectorAll('th').forEach(function (t) { t.classList.remove('sorted'); });
  var th = document.getElementById('th-' + field); if (th) th.classList.add('sorted');
  document.querySelectorAll('[id^="arr-"]').forEach(function (e) { e.textContent = ''; });
  var arr = document.getElementById('arr-' + field); if (arr) arr.textContent = sortAsc ? '' : '';
  sortApps(); renderTable();
}

function sortApps() {
  filteredApps.sort(function (a, b) {
    var va = a[sortField] || '', vb = b[sortField] || '';
    if (sortField === 'installSizeRaw') return sortAsc ? (va - vb) : (vb - va);
    va = String(va).toLowerCase(); vb = String(vb).toLowerCase();
    if (va < vb) return sortAsc ? -1 : 1;
    if (va > vb) return sortAsc ? 1 : -1;
    return 0;
  });
}

function renderTable() {
  var tbody = document.getElementById('tableBody');
  var totalPages = Math.max(1, Math.ceil(filteredApps.length / pageSize));
  if (currentPage > totalPages) currentPage = totalPages;
  var start = (currentPage - 1) * pageSize;
  var slice = filteredApps.slice(start, start + pageSize);
  var icon = '/pluginadmin.ashx?pin=' + PLUGIN_PIN + '&user=1&include=icons/default.png';
  tbody.innerHTML = slice.map(function (a) {
    var archBadge = a.architecture ? '<span class="badge b-arch">' + esc(a.architecture) + '</span>' : '<span style="color:var(--text-muted)"></span>';
    var typeBadge = a.systemComponent ? '<span class="badge b-sys">Sistema</span>' : '<span class="badge b-usr">Usuário</span>';
    return '<tr>'
      + '<td><div class="icon-cell"><img class="app-icon" src="' + icon + '" alt="" onerror="this.style.display=\'none\'">'
      + '<div><div class="app-name" title="' + esc(a.name) + '">' + esc(trunc(a.name,42)) + '</div>'
      + '<div class="app-ver">' + esc(a.version || '') + '</div></div></div></td>'
      + '<td title="' + esc(a.publisher) + '">' + esc(trunc(a.publisher, 36) || '') + '</td>'
      + '<td>' + esc(a.installDate || '') + '</td>'
      + '<td>' + esc(a.installSize || '') + '</td>'
      + '<td>' + archBadge + '</td>'
      + '<td>' + typeBadge + '</td>'
      + '</tr>';
  }).join('');
  var pager = document.getElementById('pager');
  if (totalPages > 1) {
    pager.style.display = '';
    document.getElementById('pageInfo').textContent = 'Página ' + currentPage + ' de ' + totalPages + ' (' + filteredApps.length + ' itens)';
    document.getElementById('btnPrev').disabled = currentPage <= 1;
    document.getElementById('btnNext').disabled = currentPage >= totalPages;
  } else { pager.style.display = 'none'; }
}

function changePage(d) { currentPage += d; renderTable(); }
function changePageSize() { pageSize = parseInt(document.getElementById('pageSz').value, 10); currentPage = 1; renderTable(); }

function updateStats(total, showing) {
  document.getElementById('cntTotal').textContent = total;
  document.getElementById('cntShow').textContent = showing;
  document.getElementById('statShow').style.display = showing !== total ? '' : 'none';
}

function exportCSV() {
  if (!filteredApps.length) return;
  var hdrs = ['Nome','Versão','Publisher','Data Instalação','Tamanho','Arquitetura','Tipo','Local de Instalação'];
  var rows = filteredApps.map(function (a) {
    return [a.name,a.version,a.publisher,a.installDate,a.installSize,a.architecture,a.systemComponent?'Sistema':'Usuário',a.installLocation]
      .map(function (v) { return '"' + (v||'').replace(/"/g,'""') + '"'; }).join(',');
  });
  var blob = new Blob(['\uFEFF' + hdrs.join(',') + '\n' + rows.join('\n')], {type:'text/csv;charset=utf-8;'});
  var url = URL.createObjectURL(blob);
  var a = document.createElement('a'); a.href = url;
  a.download = 'software-inventory-' + new Date().toISOString().slice(0,10) + '.csv';
  a.click(); URL.revokeObjectURL(url);
  toast('CSV exportado com ' + filteredApps.length + ' itens');
}

function setState(s) {
  document.getElementById('stateLoading').style.display = s==='loading' ? '' : 'none';
  document.getElementById('stateError').style.display   = s==='error'   ? '' : 'none';
  document.getElementById('stateEmpty').style.display   = s==='empty'   ? '' : 'none';
  document.getElementById('mainTable').style.display    = s==='table'   ? '' : 'none';
}
function showError(msg) { setState('error'); document.getElementById('errMsg').textContent = msg; }
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function trunc(s,n) { s=s||''; return s.length>n ? s.slice(0,n)+'' : s; }
function toast(msg) {
  var w = document.getElementById('toastWrap'), el = document.createElement('div');
  el.className = 'toast'; el.textContent = msg; w.appendChild(el);
  setTimeout(function(){el.remove();}, 3500);
}
</script>
</body>
</html>
